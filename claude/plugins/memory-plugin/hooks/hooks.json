{
  "hooks": {
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/memory-hook.sh",
            "async": true,
            "timeout": 120,
            "statusMessage": "Updating project memory..."
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/memory-hook.sh",
            "async": true,
            "timeout": 120
          }
        ]
      }
    ]
  }
}
